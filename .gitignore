# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform crash logs
crash.log

# Terraform variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file (optional but many teams keep it)
# Uncomment if you want to ignore it
# .terraform.lock.hcl

# MacOS
.DS_Store

# IDE
.vscode/

# Environment files
.env